<Window x:Class="VirtualMouse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        Width="270" Height="290"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="130"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ 红点固定指针 ═══ -->
        <Grid Grid.Row="0" Background="Transparent"
              MouseRightButtonDown="Canvas_ContextMenu">

            <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
                  Margin="0,10,0,0">
                <Ellipse Width="18" Height="18" Fill="#20F03C32"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Ellipse Width="10" Height="10" Fill="#FFF03C32"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Ellipse Width="14" Height="14" Stroke="#FFFFFFFF" StrokeThickness="1.5"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <Line Stroke="#25FFFFFF" StrokeThickness="1"
                  StrokeDashArray="3,3" X1="135" Y1="65" X2="135" Y2="130"
                  IsHitTestVisible="False"/>
        </Grid>

        <!-- ═══ 鼠标身体 ═══ -->
        <Border Grid.Row="1" CornerRadius="14,14,18,18"
                Background="#60202020"
                BorderBrush="#28FFFFFF"
                BorderThickness="1"
                MouseLeftButtonDown="Body_Drag"
                MouseRightButtonDown="Canvas_ContextMenu"
                MouseLeave="ResetHover">

            <Grid Margin="14,6,14,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="✕" HorizontalAlignment="Right"
                           Foreground="#40FFFFFF" FontSize="12" FontWeight="Bold"
                           Cursor="Hand" Margin="0,-2,-4,0"
                           MouseLeftButtonDown="CloseBtn_Click"
                           MouseEnter="CloseBtn_MouseEnter"
                           MouseLeave="CloseBtn_MouseLeave"/>

                <!-- ═══ 按钮区 ═══ -->
                <Grid Grid.Row="1" Margin="0,2,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="54"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="BtnLeft" Grid.Column="0"
                                CornerRadius="10,4,4,10"
                                Background="#FF505050" Cursor="Hand"
                                MouseLeftButtonDown="BtnLeft_Click"
                                MouseEnter="BtnLeft_MouseEnter"
                                MouseLeave="BtnLeft_MouseLeave"/>

                        <Border Grid.Column="1" CornerRadius="7"
                                Background="#FF353535" Margin="1,0"/>

                        <Border x:Name="BtnRight" Grid.Column="2"
                                CornerRadius="4,10,10,4"
                                Background="#FF484848" Cursor="Hand"
                                MouseLeftButtonDown="BtnRight_Click"
                                MouseEnter="BtnRight_MouseEnter"
                                MouseLeave="BtnRight_MouseLeave"/>
                    </Grid>

                    <Border x:Name="BtnMiddle" Grid.Row="1"
                            Width="32" Height="34" CornerRadius="16"
                            Background="#FF404040"
                            BorderBrush="#FF666666"
                            BorderThickness="0.5"
                            Cursor="Hand"
                            HorizontalAlignment="Center" Margin="0,-10,0,0"
                            MouseLeftButtonDown="BtnMiddle_Click"
                            MouseEnter="BtnMiddle_MouseEnter"
                            MouseLeave="BtnMiddle_MouseLeave">
                        <Grid>
                            <Rectangle Fill="#FF808080" RadiusX="2" RadiusY="2"
                                       Width="10" Height="2" Margin="0,5,0,0" VerticalAlignment="Top"/>
                            <Rectangle Fill="#FF808080" RadiusX="2" RadiusY="2"
                                       Width="10" Height="2" Margin="0,14,0,0" VerticalAlignment="Top"/>
                            <Rectangle Fill="#FF808080" RadiusX="2" RadiusY="2"
                                       Width="10" Height="2" Margin="0,23,0,0" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ═══ 肚子拖拽区 ═══ -->
                <Border Grid.Row="2" CornerRadius="10"
                        Background="#15FFFFFF"
                        Cursor="SizeAll"
                        Margin="6,6,6,4"
                        MouseLeftButtonDown="Body_Drag">
                    <TextBlock Text="⋮⋮⋮"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#20FFFFFF" FontSize="14"
                               Margin="0,2,0,0"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
